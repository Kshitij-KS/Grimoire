# Grimoire — environment variables
#
# Copy this file to `.env.local` and fill in the values.
# `.env.local` and other `.env*` files are gitignored; only `.env.example` is tracked.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser — keep secrets out of them.

# ── Supabase ──────────────────────────────────────────────────────────────
# Project URL and keys from your Supabase project settings (API section).
NEXT_PUBLIC_SUPABASE_URL=            # Supabase project URL (browser-safe)
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # Supabase anonymous/publishable key (browser-safe)
SUPABASE_SERVICE_ROLE_KEY=           # Server-only. Bypasses RLS — used by the Inngest worker and eval webhook. Never expose to the browser.

# ── Generation (Groq) ─────────────────────────────────────────────────────
# All LLM text generation runs on Groq. Required for generation to work.
GROQ_API_KEY=                        # Groq API key (soul chat/generate, entity extraction, consistency, autocomplete, tavern, demo chat)

# ── Embeddings (HuggingFace) ──────────────────────────────────────────────
# Vector embeddings run on the HuggingFace Inference API
# (sentence-transformers/all-mpnet-base-v2, 768-dim) via lib/embedding/service.ts.
HF_TOKEN=                            # Optional but recommended. Anonymous access works but is rate-limited; a free HF token removes that.
EMBEDDING_FALLBACK_TOKEN=            # Optional. Token for a fallback embedding provider (used only if BOTH token and model are set).
EMBEDDING_FALLBACK_MODEL=            # Optional. Fallback embedding model id (used only if BOTH token and model are set).

# ── Inngest (background lore processing) ──────────────────────────────────
# Use "test" for both keys during local dev (with `npx inngest-cli@latest dev`).
# Get real keys from app.inngest.com for production.
INNGEST_EVENT_KEY=                   # Inngest event key
INNGEST_SIGNING_KEY=                 # Inngest signing key

# ── Monitoring (Sentry + PostHog) ─────────────────────────────────────────
# All optional — each integration no-ops/disables itself when its key is unset.
NEXT_PUBLIC_SENTRY_DSN=              # Sentry DSN. Sentry is disabled when this is unset.
NEXT_PUBLIC_POSTHOG_KEY=             # PostHog project key. PostHog no-ops when unset.
NEXT_PUBLIC_POSTHOG_HOST=            # PostHog host. Defaults to https://us.i.posthog.com when unset.

# ── Eval harness (dev-only) ───────────────────────────────────────────────
# The /api/eval/* routes are rejected outside NODE_ENV=development.
EVAL_WEBHOOK_SECRET=                 # Required for the eval webhook to accept writes; the handler fails closed (503) when unset.
