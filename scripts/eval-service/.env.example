# Grimoire lm-eval Sidecar — Environment Variables
# Copy this file to .env and fill in your values

# ── Required ────────────────────────────────────────────────
# Your Groq API key (same as GROQ_API_KEY in the Next.js project)
GROQ_API_KEY=gsk_...

# Supabase service role key (for direct DB writes from the sidecar)
# Get from: Supabase Dashboard → Project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Optional ────────────────────────────────────────────────
# Base URL of your Next.js app (for webhook callbacks)
# Default: http://localhost:3000
NEXTJS_BASE_URL=http://localhost:3000

# Port for the sidecar FastAPI server
# Default: 8001
EVAL_SERVICE_PORT=8001

# Shared secret between Next.js and the sidecar (recommended in production)
# Must match EVAL_SIDECAR_SECRET in your Next.js .env.local
SIDECAR_SECRET=change-me-in-production

# Shared secret for the incoming webhook endpoint
# Must match EVAL_WEBHOOK_SECRET in your Next.js .env.local
WEBHOOK_SECRET=change-me-in-production
